{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neurosearch-analyzer.local/schemas/client_report_input.schema.json",
  "title": "Client Report Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "audit_id",
    "package_status",
    "methodology",
    "site",
    "summary",
    "indices",
    "strengths",
    "priority_areas",
    "action_plan",
    "constraints",
    "evidence_sources"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "audit_id": {
      "type": "string",
      "minLength": 1
    },
    "package_status": {
      "type": "string",
      "enum": ["approved"]
    },
    "methodology": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score_engine",
        "legacy_reference",
        "report_parity",
        "score_parity"
      ],
      "properties": {
        "score_engine": {"type": "string"},
        "legacy_reference": {"type": "string"},
        "report_parity": {"type": "string", "enum": ["partial", "aligned"]},
        "score_parity": {"type": "string", "enum": ["not_aligned", "aligned"]}
      }
    },
    "site": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_domain", "primary_url", "site_profile"],
      "properties": {
        "primary_domain": {"type": "string"},
        "primary_url": {"type": "string", "format": "uri"},
        "site_profile": {"type": "string"}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overview",
        "primary_risk",
        "primary_opportunity",
        "next_step",
        "page_count",
        "p0_coverage_targets",
        "high_contradiction_count"
      ],
      "properties": {
        "overview": {"type": "string"},
        "primary_risk": {"type": "string"},
        "primary_opportunity": {"type": "string"},
        "next_step": {"type": "string"},
        "page_count": {"type": "integer", "minimum": 0},
        "p0_coverage_targets": {"type": "integer", "minimum": 0},
        "high_contradiction_count": {"type": "integer", "minimum": 0}
      }
    },
    "indices": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lead_value_index", "dimensions", "legacy_scores"],
      "properties": {
        "lead_value_index": {"type": "number"},
        "dimensions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["SEO", "GEO", "AEO", "AIO", "LEO"],
          "properties": {
            "SEO": {"type": "number"},
            "GEO": {"type": "number"},
            "AEO": {"type": "number"},
            "AIO": {"type": "number"},
            "LEO": {"type": "number"}
          }
        },
        "legacy_scores": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "label", "score", "description", "measured_factor_count", "total_factor_count", "levels_covered"],
            "properties": {
              "key": {"type": "string"},
              "label": {"type": "string"},
              "score": {"type": "number"},
              "description": {"type": "string"},
              "measured_factor_count": {"type": "integer", "minimum": 0},
              "total_factor_count": {"type": "integer", "minimum": 0},
              "levels_covered": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      }
    },
    "strengths": {
      "type": "array",
      "items": {"type": "string"}
    },
    "priority_areas": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "why_it_matters", "top_missing"],
        "properties": {
          "label": {"type": "string"},
          "why_it_matters": {"type": "string"},
          "top_missing": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "action_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["priority", "summary", "expected_impact", "related_findings_count"],
        "properties": {
          "priority": {"type": "string"},
          "summary": {"type": "string"},
          "expected_impact": {"type": "string"},
          "related_findings_count": {"type": "integer", "minimum": 0}
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": {"type": "string"}
    },
    "evidence_sources": {
      "type": "array",
      "items": {"type": "string", "format": "uri"}
    }
  }
}
