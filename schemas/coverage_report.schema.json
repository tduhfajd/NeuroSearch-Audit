{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neurosearch-analyzer.local/schemas/coverage_report.schema.json",
  "title": "Coverage Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "audit_id",
    "coverage_ruleset",
    "items",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "audit_id": {
      "type": "string",
      "pattern": "^aud_[0-9]{8}T[0-9]{6}Z_[a-z0-9]{6,}$"
    },
    "coverage_ruleset": {
      "type": "string",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target",
          "coverage_score",
          "missing",
          "priority",
          "impact",
          "evidence"
        ],
        "properties": {
          "target": {
            "type": "string",
            "minLength": 1
          },
          "coverage_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "missing": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "priority": {
            "type": "string",
            "enum": ["P0", "P1", "P2"]
          },
          "impact": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "source_url",
                "field"
              ],
              "properties": {
                "source_url": {
                  "type": "string",
                  "format": "uri"
                },
                "field": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    }
  }
}
