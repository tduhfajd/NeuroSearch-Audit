{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neurosearch-analyzer.local/schemas/manifest.schema.json",
  "title": "Audit Package Manifest",
  "description": "Manifest describing the integrity, versions, and contents of an audit package.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "audit_id",
    "created_at",
    "ruleset_versions",
    "schema_versions",
    "stage_status",
    "files"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "audit_id": {
      "type": "string",
      "pattern": "^aud_[0-9]{8}T[0-9]{6}Z_[a-z0-9]{6,}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "ruleset_versions": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "schema_versions": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
      }
    },
    "stage_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "crawl",
        "extract",
        "analyze",
        "package",
        "validate"
      ],
      "properties": {
        "crawl": {
          "$ref": "#/$defs/stageState"
        },
        "extract": {
          "$ref": "#/$defs/stageState"
        },
        "analyze": {
          "$ref": "#/$defs/stageState"
        },
        "package": {
          "$ref": "#/$defs/stageState"
        },
        "validate": {
          "$ref": "#/$defs/stageState"
        }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/fileEntry"
      }
    }
  },
  "$defs": {
    "stageState": {
      "type": "string",
      "enum": [
        "pending",
        "completed",
        "failed",
        "rejected"
      ]
    },
    "fileEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "category",
        "required",
        "schema"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": [
            "audit",
            "crawl",
            "page",
            "analysis",
            "export",
            "prompt",
            "validation"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "schema": {
          "type": "string",
          "minLength": 0
        },
        "checksum": {
          "type": "string"
        }
      }
    }
  }
}
