{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neurosearch-analyzer.local/schemas/render_plan.schema.json",
  "title": "Render Plan Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "audit_id",
    "generated_at",
    "summary",
    "candidates"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "audit_id": {
      "type": "string",
      "pattern": "^aud_[0-9]{8}T[0-9]{6}Z_[a-z0-9]{6,}$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_pages",
        "render_required_count",
        "plain_fetch_count"
      ],
      "properties": {
        "total_pages": {
          "type": "integer",
          "minimum": 0
        },
        "render_required_count": {
          "type": "integer",
          "minimum": 0
        },
        "plain_fetch_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "url",
          "reason",
          "wait_selectors",
          "signals"
        ],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "wait_selectors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "signals": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "html_bytes",
              "visible_text_chars",
              "script_tag_count",
              "noscript_hint",
              "url_hint"
            ],
            "properties": {
              "content_type": {
                "type": "string"
              },
              "html_bytes": {
                "type": "integer",
                "minimum": 0
              },
              "visible_text_chars": {
                "type": "integer",
                "minimum": 0
              },
              "script_tag_count": {
                "type": "integer",
                "minimum": 0
              },
              "noscript_hint": {
                "type": "boolean"
              },
              "url_hint": {
                "type": "boolean"
              }
            }
          }
        }
      }
    }
  }
}
