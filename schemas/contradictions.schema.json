{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neurosearch-analyzer.local/schemas/contradictions.schema.json",
  "title": "Contradictions Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "audit_id",
    "contradictions"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "audit_id": {
      "type": "string",
      "pattern": "^aud_[0-9]{8}T[0-9]{6}Z_[a-z0-9]{6,}$"
    },
    "contradictions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "contradiction_id",
          "entity_id",
          "type",
          "severity",
          "sources",
          "risk"
        ],
        "properties": {
          "contradiction_id": {
            "type": "string",
            "minLength": 1
          },
          "entity_id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "sources": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "string",
              "format": "uri"
            }
          },
          "risk": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
