{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neurosearch-analyzer.local/schemas/batch_run_manifest.schema.json",
  "title": "Batch Run Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "batch_id",
    "items"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "batch_id": {
      "type": "string",
      "minLength": 1
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_depth": {
          "type": "integer",
          "minimum": 0
        },
        "python_bin": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "url"
        ],
        "properties": {
          "label": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "html_file": {
            "type": "string",
            "minLength": 1
          },
          "fixture_mode": {
            "type": "boolean"
          },
          "max_depth": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
