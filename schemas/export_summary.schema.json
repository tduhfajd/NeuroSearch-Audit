{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neurosearch-analyzer.local/schemas/export_summary.schema.json",
  "title": "Export Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "audit_id",
    "status",
    "lead_value_index",
    "top_gaps",
    "high_contradictions",
    "package_status"
  ],
  "properties": {
    "audit_id": {
      "type": "string",
      "pattern": "^aud_[0-9]{8}T[0-9]{6}Z_[a-z0-9]{6,}$"
    },
    "status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["crawl", "extract", "analyze", "package", "validate"],
      "properties": {
        "crawl": { "type": "string" },
        "extract": { "type": "string" },
        "analyze": { "type": "string" },
        "package": { "type": "string" },
        "validate": { "type": "string" }
      }
    },
    "lead_value_index": {
      "type": "number"
    },
    "top_gaps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "high_contradictions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "package_status": {
      "type": "string",
      "enum": ["approved", "pending"]
    }
  }
}
