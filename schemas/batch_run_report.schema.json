{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neurosearch-analyzer.local/schemas/batch_run_report.schema.json",
  "title": "Batch Run Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "batch_id",
    "started_at",
    "finished_at",
    "status",
    "items"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "batch_id": {
      "type": "string",
      "minLength": 1
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["running", "completed", "failed"]
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "index",
          "url",
          "status"
        ],
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 0
          },
          "label": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "audit_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["completed", "failed"]
          },
          "error": {
            "type": "string"
          }
        }
      }
    }
  }
}
