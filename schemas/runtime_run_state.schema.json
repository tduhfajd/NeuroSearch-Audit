{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neurosearch.dev/schemas/runtime_run_state.schema.json",
  "title": "Runtime Run State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "audit_id",
    "attempt",
    "status",
    "submitted_url",
    "normalized_host",
    "ruleset_version",
    "started_at",
    "updated_at",
    "stages",
    "transitions"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "audit_id": {
      "type": "string",
      "minLength": 1
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": ["pending", "running", "failed", "completed", "cancelled"]
    },
    "submitted_url": {
      "type": "string",
      "minLength": 1
    },
    "normalized_host": {
      "type": "string",
      "minLength": 1
    },
    "ruleset_version": {
      "type": "string",
      "minLength": 1
    },
    "current_stage": {
      "type": "string",
      "enum": ["crawling", "extracting", "analyzing", "packaging", "validating"]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "code", "message"],
      "properties": {
        "stage": {
          "type": "string",
          "enum": ["crawling", "extracting", "analyzing", "packaging", "validating"]
        },
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stage", "status", "attempt"],
        "properties": {
          "stage": {
            "type": "string",
            "enum": ["crawling", "extracting", "analyzing", "packaging", "validating"]
          },
          "status": {
            "type": "string",
            "enum": ["pending", "running", "completed", "failed", "cancelled"]
          },
          "attempt": {
            "type": "integer",
            "minimum": 1
          },
          "max_attempts": {
            "type": "integer",
            "minimum": 1
          },
          "retry_count": {
            "type": "integer",
            "minimum": 0
          },
          "worker_id": {
            "type": "string"
          },
          "started_at": {
            "type": "string",
            "format": "date-time"
          },
          "finished_at": {
            "type": "string",
            "format": "date-time"
          },
          "inputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "error_code": {
            "type": "string"
          },
          "error_message": {
            "type": "string"
          },
          "retry_history": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["attempt", "at", "error_code", "error_message"],
              "properties": {
                "attempt": {
                  "type": "integer",
                  "minimum": 1
                },
                "at": {
                  "type": "string",
                  "format": "date-time"
                },
                "error_code": {
                  "type": "string"
                },
                "error_message": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["event", "attempt", "at"],
        "properties": {
          "event": {
            "type": "string",
            "enum": ["initialized", "stage_started", "stage_completed", "stage_failed", "stage_retried"]
          },
          "stage": {
            "type": "string",
            "enum": ["crawling", "extracting", "analyzing", "packaging", "validating"]
          },
          "status": {
            "type": "string",
            "enum": ["pending", "running", "completed", "failed", "cancelled"]
          },
          "attempt": {
            "type": "integer",
            "minimum": 1
          },
          "at": {
            "type": "string",
            "format": "date-time"
          },
          "worker_id": {
            "type": "string"
          },
          "error_code": {
            "type": "string"
          },
          "error_message": {
            "type": "string"
          }
        }
      }
    }
  }
}
