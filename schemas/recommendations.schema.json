{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neurosearch-analyzer.local/schemas/recommendations.schema.json",
  "title": "Recommendations Document",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "audit_id",
    "recommendations"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "audit_id": {
      "type": "string",
      "pattern": "^aud_[0-9]{8}T[0-9]{6}Z_[a-z0-9]{6,}$"
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "recommendation_id",
          "related_findings",
          "priority",
          "effort",
          "expected_impact",
          "acceptance_criteria"
        ],
        "properties": {
          "recommendation_id": {
            "type": "string",
            "minLength": 1
          },
          "related_findings": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "priority": {
            "type": "string",
            "enum": ["P0", "P1", "P2"]
          },
          "effort": {
            "type": "string",
            "minLength": 1
          },
          "expected_impact": {
            "type": "string",
            "minLength": 1
          },
          "acceptance_criteria": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
