{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neurosearch-analyzer.local/schemas/crawl/fetch_log.schema.json",
  "title": "Fetch Log Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "audit_id",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "audit_id": {
      "type": "string",
      "pattern": "^aud_[0-9]{8}T[0-9]{6}Z_[a-z0-9]{6,}$"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "url",
          "normalized_url",
          "depth",
          "source",
          "status"
        ],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "normalized_url": {
            "type": "string",
            "format": "uri"
          },
          "depth": {
            "type": "integer",
            "minimum": 0
          },
          "source": {
            "type": "string",
            "enum": [
              "submitted",
              "sitemap",
              "discovered"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "fetched",
              "failed",
              "skipped"
            ]
          },
          "status_code": {
            "type": "integer",
            "minimum": 100,
            "maximum": 599
          },
          "content_type": {
            "type": "string"
          },
          "strict_transport_security": {
            "type": "string"
          },
          "error": {
            "type": "string"
          },
          "fetched_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
