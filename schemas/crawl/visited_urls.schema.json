{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neurosearch-analyzer.local/schemas/crawl/visited_urls.schema.json",
  "title": "Visited URLs Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "audit_id",
    "visited_urls",
    "skipped_urls",
    "filtered_urls",
    "failure_count",
    "throttle_policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "audit_id": {
      "type": "string",
      "pattern": "^aud_[0-9]{8}T[0-9]{6}Z_[a-z0-9]{6,}$"
    },
    "visited_urls": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "skipped_urls": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "filtered_urls": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "failure_count": {
      "type": "integer",
      "minimum": 0
    },
    "throttle_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_request_interval_ms",
        "max_inflight_per_host"
      ],
      "properties": {
        "min_request_interval_ms": {
          "type": "integer",
          "minimum": 0
        },
        "max_inflight_per_host": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
