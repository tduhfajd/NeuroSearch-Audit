{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Legacy Index Scores",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "audit_id", "weights_version", "missing_data_policy", "indices"],
  "properties": {
    "schema_version": { "type": "string" },
    "audit_id": { "type": "string" },
    "weights_version": { "type": "string" },
    "missing_data_policy": { "type": "object" },
    "indices": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["score", "description", "coverage", "breakdown"],
        "properties": {
          "score": { "type": "number" },
          "description": { "type": "string" },
          "coverage": {
            "type": "object",
            "additionalProperties": false,
            "required": ["measured_factor_count", "total_factor_count", "levels_covered"],
            "properties": {
              "measured_factor_count": { "type": "integer", "minimum": 0 },
              "total_factor_count": { "type": "integer", "minimum": 0 },
              "levels_covered": { "type": "array", "items": { "type": "string" } }
            }
          },
          "breakdown": { "type": "object" }
        }
      }
    }
  }
}
